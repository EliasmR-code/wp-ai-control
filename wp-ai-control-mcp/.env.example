# WordPress (OPCIONAL - solo modo single-tenant / fallback)
# El MCP es multi-tenant por defecto: cada tool call lleva su propio site_url y api_key.
# En un MCP compartido (varios usuarios en el mismo Railway): NO definas WP_URL ni WP_API_KEY.
# Define WP_URL y WP_API_KEY solo si el servidor es dedicado a un único sitio y quieres credenciales por defecto.
# WP_URL=https://tu-sitio.com
# WP_API_KEY=wpaic_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Peticiones al REST de WordPress (opcional)
# WP_FETCH_TIMEOUT_MS=60000
# WP_FETCH_USER_AGENT=mi-mcp/1.0

# Proxy (Railway / load balancer). Desactivar: TRUST_PROXY=0
# TRUST_PROXY=1

# Modo transporte (opcional)
# - En Railway: HTTP por defecto (Streamable HTTP en /mcp). Usa MCP_TRANSPORT=stdio solo si quieres forzar stdio.
# - En tu PC: stdio por defecto. Para probar HTTP local: MCP_TRANSPORT=http y PORT=3000
# MCP_TRANSPORT=http
# PORT=3000
# MCP_PATH=/mcp

# Hardening opcional (DNS rebinding)
# MCP_ALLOWED_HOSTS=tu-host.up.railway.app
