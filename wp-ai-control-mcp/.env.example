# WordPress (OPCIONAL - solo modo single-tenant)
# El MCP es multi-tenant por defecto: cada tool call lleva su propio site_url y api_key.
# Define WP_URL y WP_API_KEY SOLO si quieres un fallback por defecto (servidor dedicado a un único sitio).
# WP_URL=https://tu-sitio.com
# WP_API_KEY=wpaic_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Modo transporte (opcional)
# - En Railway: HTTP por defecto (Streamable HTTP en /mcp). Usa MCP_TRANSPORT=stdio solo si quieres forzar stdio.
# - En tu PC: stdio por defecto. Para probar HTTP local: MCP_TRANSPORT=http y PORT=3000
# MCP_TRANSPORT=http
# PORT=3000
# MCP_PATH=/mcp

# Hardening opcional (DNS rebinding)
# MCP_ALLOWED_HOSTS=tu-host.up.railway.app
